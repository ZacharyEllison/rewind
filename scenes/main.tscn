[sub_resource type="GDScript" id="GDScript_player_coords"]
script/source = "extends CanvasLayer

@export var tracked_node_path: NodePath = NodePath(\"../XROrigin3D\")

@onready var _coordinates_label: Label = $CoordinatesLabel

var _tracked_node: Node3D = null


func _ready() -> void:
\t_resolve_tracked_node()
\t_update_text()


func _process(_delta: float) -> void:
\tif not _tracked_node or not is_instance_valid(_tracked_node):
\t\t_resolve_tracked_node()
\t_update_text()


func _resolve_tracked_node() -> void:
\t_tracked_node = null
\tif not tracked_node_path.is_empty():
\t\t_tracked_node = get_node_or_null(tracked_node_path) as Node3D
\tif _tracked_node:
\t\treturn
\tvar parent := get_parent()
\tif parent:
\t\t_tracked_node = parent.get_node_or_null(\"XROrigin3D\") as Node3D


func _update_text() -> void:
\tif not _coordinates_label:
\t\treturn
\tif not _tracked_node:
\t\t_coordinates_label.text = \"Player\\nX: --\\nY: --\\nZ: --\"
\t\treturn
\tvar pos := _tracked_node.global_position
\t_coordinates_label.text = \"Player\\nX: %.3f\\nY: %.3f\\nZ: %.3f\" % [pos.x, pos.y, pos.z]
"

